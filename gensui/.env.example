# ── Gensui Server Configuration ──────────────────────────────
# Copy this file to .env and customize for your deployment.

# Server
GENSUI_SERVER_HOST=0.0.0.0
GENSUI_SERVER_PORT=8787
DEBUG=false

# Database (SQLite default, change for PostgreSQL)
GENSUI_DATABASE_URL=sqlite+aiosqlite:///./data/gensui.db

# Security — CHANGE THESE IN PRODUCTION
GENSUI_JWT_SECRET=change-me-to-a-random-64-char-string
GENSUI_JWT_EXPIRE_HOURS=24

# Initial Admin Account — CHANGE PASSWORD AFTER FIRST LOGIN
GENSUI_ADMIN_EMAIL=admin@gensui.local
GENSUI_ADMIN_PASSWORD=changeme

# Enrollment
GENSUI_REQUIRE_ENROLLMENT_APPROVAL=true
GENSUI_DEFAULT_POSTURE=STANDARD

# Telemetry
GENSUI_TELEMETRY_DEFAULT_MODE=STANDARD

# Harakiri Controls
GENSUI_ENABLE_GLOBAL_HARAKIRI=true
GENSUI_ENABLE_GROUP_HARAKIRI=true
GENSUI_ENABLE_INDIVIDUAL_HARAKIRI=true

# Heartbeat
GENSUI_HEARTBEAT_TIMEOUT_SECONDS=60
