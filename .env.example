# ── Shogun Environment Configuration ─────────────────────────
# Copy this to .env and adjust as needed.

# Application
APP_ENV=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
# Uncomment below for development (enables SQL echo logging):
# APP_ENV=development
# DEBUG=true

# Database — SQLite (default, zero-install)
DATABASE_URL=sqlite+aiosqlite:///./data/shogun.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://shogun:shogun_dev_password@localhost:5432/shogun

# Qdrant — Embedded mode (default, no Docker needed)
# Leave QDRANT_URL empty for embedded mode with local storage
# QDRANT_URL=http://localhost:6333
QDRANT_PATH=./data/qdrant

# Security
SECRET_KEY=change-me-to-a-random-64-char-string
VAULT_ENCRYPTION_KEY=change-me-to-a-fernet-base64-key

# Storage
VAULT_PATH=./vault
LOG_PATH=./logs
CONFIG_PATH=./configs

# Telegram (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=

# Microsoft Teams adapter (store secret values in a vault; configure references here)
TEAMS_ADAPTER_ENABLED=false
TEAMS_DEPLOYMENT_MODE=dev
TEAMS_TENANT_MODE=single
TEAMS_ALLOWED_TENANT_IDS=
TEAMS_BOT_APP_ID=
TEAMS_BOT_CLIENT_SECRET_REF=
TEAMS_PUBLIC_MESSAGING_ENDPOINT=
TEAMS_SSO_ENABLED=false
TEAMS_GRAPH_ENABLED=false
TEAMS_PROACTIVE_ENABLED=false
TEAMS_MANIFEST_VALID_DOMAINS=
TEAMS_RATE_LIMIT_PER_USER_PER_MINUTE=20
TEAMS_RATE_LIMIT_PER_CHANNEL_PER_MINUTE=60
TEAMS_HIGH_RISK_CONFIRMATION_TTL_SECONDS=300
TEAMS_BRIDGE_URL=http://127.0.0.1:3978
SHOGUN_INTERNAL_API_URL=http://127.0.0.1:8000
SHOGUN_INTERNAL_API_KEY_REF=
# SHOGUN_INTERNAL_API_KEY is injected by the runtime/secret store, not committed to .env.
